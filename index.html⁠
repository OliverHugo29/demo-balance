<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Budget Tracker</title>
    <style>
        /* Modern, Clean Style with "Nice Colors" */
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: #f4f6f9;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        .account-card {
            background: #ffffff;
            padding: 30px;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            width: 350px;
            text-align: center;
        }

        .greeting {
            color: #64748b;
            font-size: 1.1rem;
            margin: 0 0 5px 0;
        }

        .balance-label {
            font-size: 0.85rem;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 0;
        }

        .balance-amount {
            font-size: 2.2rem;
            font-weight: 700;
            color: #0f172a;
            margin: 10px 0 25px 0;
        }

        .input-group {
            margin-bottom: 15px;
        }

        input {
            width: 100%;
            padding: 12px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            box-sizing: border-box;
            font-size: 1rem;
            outline: none;
            transition: border 0.2s;
        }

        input:focus {
            border-color: #3b82f6;
        }

        .btn-group {
            display: flex;
            gap: 10px;
        }

        button {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        button:hover {
            opacity: 0.9;
        }

        /* The Nice Colors requested */
        .btn-deposit {
            background-color: #10b981; /* Nice Green */
            color: white;
        }

        .btn-spend {
            background-color: #ef4444; /* Nice Red */
            color: white;
        }
    </style>
</head>
<body>

    <div class="account-card">
        <h2 class="greeting" id="display-name">Hi Oliver</h2>
        <p class="balance-label">Available Balance (USD)</p>
        <div class="balance-amount" id="display-balance">$360,000.00</div>

        <div class="input-group">
            <input type="number" id="amount-input" placeholder="Amount ($)">
        </div>

        <div class="btn-group">
            <button class="btn-deposit" onclick="handleTransaction('deposit')">Deposit (+)</button>
            <button class="btn-spend" onclick="handleTransaction('spend')">Spend (-)</button>
        </div>
    </div>

    <script>
        // Track the current balance as a number
        let currentBalance = 360000.00;

        function handleTransaction(type) {
            const inputField = document.getElementById('amount-input');
            const amount = parseFloat(inputField.value);

            // Validation: Ensure a valid number is entered
            if (isNaN(amount) || amount <= 0) {
                alert("Please enter a valid amount.");
                return;
            }

            // Math logic
            if (type === 'deposit') {
                currentBalance += amount;
            } else if (type === 'spend') {
                if (amount > currentBalance) {
                    alert("Insufficient funds.");
                    return;
                }
                currentBalance -= amount;
            }

            // Update the display with proper currency formatting
            document.getElementById('display-balance').innerText = 
                '$' + currentBalance.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

            // Clear the input field
            inputField.value = '';
        }
    </script>

</body>
</html>
 
